# Copy to .env and customize. `lexicon` reads these automatically.

# Postgres (docker-compose path — matches docker-compose.yml defaults)
LEXICON_DATABASE_URL=postgresql://lexicon:lexicon@localhost:5433/lexicon
LEXICON_POSTGRES_PORT=5433

# API (localhost-only at v0 — do not bind to 0.0.0.0 without adding auth)
LEXICON_API_HOST=127.0.0.1
LEXICON_API_PORT=8000

# Anthropic API (used by the bootstrap ingestion skill)
ANTHROPIC_API_KEY=

# Embedding model for pgvector (defaults to voyage-3 if unset)
LEXICON_EMBEDDING_MODEL=voyage-3
